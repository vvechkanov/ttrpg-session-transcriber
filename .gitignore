# Generated by installer — do not commit
venv/
tools/
__pycache__/
*.pyc

# Runtime logs
_run_whisperx_gui.log
app_run.log

# User data — only the project-root speaker_map (legacy location).
# Bare ``speaker_map.json`` would also match in-repo fixtures
# (tests/fixtures/e2e_p2/session/speaker_map.json), which broke CI
# after a fresh checkout.
/speaker_map.json
.claude/

# Test output
Тестовое/

# Launcher build artifacts
launcher/dist/
launcher/build/
launcher/*.zip
*.exe

# PyInstaller
*.spec.bak

# Design handoff bundle — canonical copy lives in docs/handoff/ (markdown).
# Root-level handoff/ was the extraction target for the now-deleted zip; keep
# the path ignored so any local re-extraction does not sneak into commits.
/handoff/

